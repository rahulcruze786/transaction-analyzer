apiVersion: ai.sap.com/v1alpha1
kind: ServingTemplate
metadata:
  name: transanalyzerpt-serving
  annotations:
    scenarios.ai.sap.com/description: "transanalyzerpt Serving Template"
    scenarios.ai.sap.com/name: "transanalyzerpt"
    executables.ai.sap.com/description: "Serve transanalyzerpt model predictions"
    executables.ai.sap.com/name: "transanalyzerpt-serving"
  labels:
    scenarios.ai.sap.com/id: "transanalyzerpt"
    ai.sap.com/version: "1.0.0"
spec:
  inputs:
    artifacts:
      - name: trainedmodels
  template:
    apiVersion: "serving.kserve.io/v1beta1"
    metadata:
      annotations: "{}"
      labels: "{\"ai.sap.com/resourcePlan\": \"starter\"}"
    spec: |
      predictor:
        minReplicas: 1
        maxReplicas: 2
        containers:
          - name: kserve-container
            image: docker.io/jerushan/transanalyzerpt-serve:latest
            ports:
              - containerPort: 8080
                protocol: TCP
            command: ["python"]
            args:
              - "prediction/app.py"
            env:
              - name: STORAGE_URI
                value: "{{inputs.artifacts.trainedmodels}}"
              - name: MODEL_PATH
                value: "/mnt/models"
            resources:
              requests:
                cpu: "0.5"
                memory: "512Mi"
              limits:
                cpu: "1"
                memory: "1Gi"
